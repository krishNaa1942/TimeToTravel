# ============================================================
# Time Travel – Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
#
#   cp .env.example .env
#
# Never commit .env to version control.
# ============================================================

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"

# Database (SQLite default – no config needed for local dev)
# DATABASE_URL=sqlite:///instance/timetravel.db
#
# Supabase Cloud Database:
#   Supabase → Settings → Database → Connection string → URI
#   Connection pooling is auto-configured for PostgreSQL (pool_size=5, max_overflow=10).
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Supabase API (PostgREST + Storage)
# Get these from https://supabase.com → Project Settings → API
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here
# Storage bucket names (created automatically in Supabase dashboard)
# SUPABASE_STORAGE_BUCKET_PHOTOS=photos
# SUPABASE_STORAGE_BUCKET_DOCS=documents

# ---------- API Keys ----------

# OpenWeatherMap – free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_key_here

# TomTom Maps – free key at https://developer.tomtom.com/
TOMTOM_API_KEY=your_key_here

# Google Gemini AI – get at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_key_here

# Unsplash Images – register at https://unsplash.com/developers
# IMPORTANT:
# - UNSPLASH_ACCESS_KEY must be the public Access Key (Client-ID), not the Secret Key.
# - If this is wrong/expired or quota is exhausted, image endpoints will use fallback photos.
UNSPLASH_ACCESS_KEY=your_key_here
UNSPLASH_SECRET_KEY=your_key_here

# Foursquare Places – register at https://developer.foursquare.com/
FOURSQUARE_API_KEY=your_key_here
FOURSQUARE_CLIENT_ID=your_key_here
FOURSQUARE_CLIENT_SECRET=your_key_here

# NewsAPI – free key at https://newsapi.org/register
NEWSAPI_KEY=your_key_here

# ---------- Mobile / Expo ----------
# Set this explicitly for native devices.
# Android emulator: http://10.0.2.2:5001/api
# iOS simulator:    http://127.0.0.1:5001/api
# Physical device:   http://<your-LAN-IP>:5001/api
# Example: EXPO_PUBLIC_API_URL=http://10.0.2.2:5001/api
# If you use a physical Android/iPhone device, also set LAN_IP in the backend shell
# so Expo and Flask agree on the host machine address.
# LAN_IP=192.168.1.50
EXPO_PUBLIC_API_URL=http://10.0.2.2:5001/api
